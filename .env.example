# Fichier de variables d'environnement (À garder secret, ne pas commiter sur un depôt public si contient des clés critiques)
# Copier ce fichier en `.env.local` pour votre machine de développement.

# CLOUDINARY CONFIGURATION (Image Optimization & CDN)
# cloud_name visible dans votre dashboard Cloudinary
VITE_CLOUDINARY_CLOUD_ID=your_cloud_name_here

# Create an unsigned upload preset in Cloudinary Settings > Upload
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_upload_preset
