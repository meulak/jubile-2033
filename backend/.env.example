PORT=3000
NODE_ENV=development

# Database Configuration (SQLite)
# database.sqlite will be created in the root directory

# Email Configuration (Nodemailer / SMTP)
# For testing: use Mailtrap or a temporary SMTP
# For production: use SendGrid, Postmark, or Gmail (with App Password)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_user_id
SMTP_PASS=your_password

# Identity Configuration
EMAIL_FROM="Jubilé 2033 <noreply@impronte-africane.com>"
ADMIN_EMAIL=admin@impronte-africane.com

# JWT Secret for Admin Auth
JWT_SECRET=your_super_secret_jwt_key
ADMIN_PASSWORD=your_admin_access_password

# Frontend URL (for links in emails and CORS)
FRONTEND_URL=http://localhost:5173
